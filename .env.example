# OmniRoute AI Proxy (required)
OMNIROUTE_BASE_URL=http://localhost:20128/v1
OMNIROUTE_API_KEY=sk-your-key-here

# REST API authentication (for adforge integration)
EBOOK_API_KEY=dev-key-change-me

# adforge integration (optional - for Push to adforge button)
ADFORGE_URL=http://localhost:3000
ADFORGE_API_KEY=your-adforge-jwt-token

# PDF export (requires LibreOffice)
# Install: apt install libreoffice
# LIBREOFFICE_PATH=/usr/bin/libreoffice  # optional override
