<style>
body {
  background: {{ primary }};
  font-family: 'Georgia', serif;
  position: relative;
  overflow: hidden;
}
.bg-circle-1 {
  position: absolute; width: 900px; height: 900px;
  border-radius: 50%;
  background: radial-gradient(circle, {{ accent }}22 0%, transparent 70%);
  top: -200px; right: -200px;
}
.bg-circle-2 {
  position: absolute; width: 600px; height: 600px;
  border-radius: 50%;
  background: radial-gradient(circle, {{ secondary }}44 0%, transparent 70%);
  bottom: 100px; left: -100px;
}
.content {
  position: absolute; left: 0; right: 0; top: 0; bottom: 0;
  display: flex; flex-direction: column;
  padding: 120px 80px 100px;
}
.genre-line {
  font-size: 20px; letter-spacing: 6px; text-transform: uppercase;
  color: {{ accent }}; margin-bottom: auto;
}
.title-block { margin-bottom: 60px; }
.title {
  font-size: {{ title_size }}px; font-weight: 900;
  color: #ffffff; line-height: 1.05;
  text-shadow: 0 2px 30px rgba(0,0,0,0.6);
  word-wrap: break-word;
}
.title-underline {
  width: 100px; height: 3px;
  background: linear-gradient(90deg, {{ accent }}, transparent);
  margin-top: 24px;
}
.subtitle {
  font-size: 30px; color: rgba(255,255,255,0.75);
  font-style: italic; margin-bottom: 60px;
}
.author-section {
  border-top: 1px solid rgba(255,255,255,0.2);
  padding-top: 30px;
}
.author {
  font-size: 28px; color: rgba(255,255,255,0.85);
  letter-spacing: 3px; text-transform: uppercase;
}
</style>
<div class="bg-circle-1"></div>
<div class="bg-circle-2"></div>
<div class="content">
  <div class="genre-line">{{ mode_label }}</div>
  <div class="title-block">
    <div class="title">{{ title }}</div>
    <div class="title-underline"></div>
  </div>
  {% if subtitle %}<div class="subtitle">{{ subtitle }}</div>{% endif %}
  <div class="author-section">
    <div class="author">{{ author }}</div>
  </div>
</div>
