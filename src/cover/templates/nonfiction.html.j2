<style>
body {
  background: linear-gradient(160deg, {{ primary }} 0%, {{ secondary }} 100%);
  font-family: 'Georgia', 'Times New Roman', serif;
  position: relative;
}
.accent-bar {
  position: absolute; top: 0; left: 0; width: 12px; height: 100%;
  background: {{ accent }};
}
.content {
  position: absolute; left: 60px; right: 60px; top: 0; bottom: 0;
  display: flex; flex-direction: column; justify-content: space-between;
  padding: 100px 60px 80px;
}
.mode-badge {
  display: inline-block;
  background: {{ accent }}33;
  border: 2px solid {{ accent }};
  color: {{ accent }};
  font-size: 22px; font-weight: bold; letter-spacing: 4px;
  text-transform: uppercase;
  padding: 10px 24px; border-radius: 4px;
  align-self: flex-start;
}
.title {
  font-size: {{ title_size }}px; font-weight: 900;
  color: #ffffff; line-height: 1.1;
  text-shadow: 0 4px 20px rgba(0,0,0,0.4);
  margin: 40px 0 24px;
  word-wrap: break-word;
}
.subtitle {
  font-size: 36px; color: rgba(255,255,255,0.85);
  font-style: italic; line-height: 1.4;
  border-left: 4px solid {{ accent }};
  padding-left: 20px;
}
.divider {
  width: 80px; height: 4px;
  background: {{ accent }};
  margin: 60px 0;
}
.author {
  font-size: 32px; color: rgba(255,255,255,0.9);
  letter-spacing: 2px; text-transform: uppercase;
}
.bottom-bar {
  position: absolute; bottom: 0; left: 0; right: 0; height: 8px;
  background: {{ accent }};
}
</style>
<div class="accent-bar"></div>
<div class="content">
  <div>
    <div class="mode-badge">{{ mode_label }}</div>
    <div class="title">{{ title }}</div>
    {% if subtitle %}<div class="subtitle">{{ subtitle }}</div>{% endif %}
  </div>
  <div>
    <div class="divider"></div>
    <div class="author">{{ author }}</div>
  </div>
</div>
<div class="bottom-bar"></div>
